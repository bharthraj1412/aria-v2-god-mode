{
  "name": "openclaw-ultimate-agent",
  "description": "OpenClaw-style runtime gateway with local-exec channel and OpenAI/Anthropic provider failover.",
  "version": "0.4.0",
  "private": true,
  "main": "./dist/index.js",
  "bin": {
    "openclaw": "./dist/cli/index.js"
  },
  "files": [
    "dist/**",
    "src/**",
    ".github/**",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "check:deps": "node scripts/check-deps.js",
    "compile": "tsc -p .",
    "watch": "tsc -watch -p .",
    "test": "npm run check:deps && npm run compile && node --test test/*.test.js",
    "onboard": "node dist/cli/index.js onboard",
    "doctor": "node dist/cli/index.js doctor",
    "harden": "node dist/cli/index.js harden",
    "rotate-token": "node dist/cli/index.js rotate-token",
    "configure": "node dist/cli/index.js configure",
    "gateway": "node dist/cli/index.js gateway",
    "status": "node dist/cli/index.js status",
    "providers": "node dist/cli/index.js providers",
    "skills": "node dist/cli/index.js skills",
    "events": "node dist/cli/index.js events",
    "chat": "node dist/cli/index.js chat"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bharthraj1412/aria-v2-god-mode.git"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.54.0",
    "openai": "^5.20.2",
    "ws": "^8.18.3",
    "yaml": "^2.8.1",
    "yargs": "^18.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@types/yargs": "^17.0.33",
    "@types/ws": "^8.18.1",
    "typescript": "^5.8.0"
  }
}
